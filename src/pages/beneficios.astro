---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Beneficios">
	<section class="py-32 relative z-10 min-h-screen overflow-hidden">
		<!-- Ambient orbs -->
		<div class="hero-orb hero-orb--purple"></div>
		<div class="hero-orb hero-orb--blue"></div>
		<div class="hero-orb hero-orb--pink"></div>
		<!-- Radial ring decoration -->
		<div class="hero-ring"></div>
		<!-- Grid pattern -->
		<div class="hero-grid"></div>
		
		<div class="container-custom relative z-10 max-w-4xl">
			<h1 class="text-5xl md:text-6xl font-black text-center mb-16 tracking-widest uppercase text-transparent bg-clip-text bg-gradient-to-r from-white via-[var(--theme-color-primary)] to-[var(--theme-color-secondary)] drop-shadow-[0_0_15px_rgba(56,189,248,0.4)]" style="font-family: var(--font-display);">
				Beneficios
			</h1>
			
			<!-- Propuesta de Valor -->
			<div class="mb-20 reveal">
				<p class="text-2xl md:text-3xl text-slate-300 leading-relaxed font-light max-w-4xl mx-auto text-center text-balance">
					Más allá de la competencia, la Innovathon te ofrece un entorno de <span class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--theme-color-primary)] to-[var(--theme-color-secondary)] font-semibold drop-shadow-sm">aceleración técnica y profesional</span> diseñado para llevar tus habilidades al siguiente nivel.
				</p>
			</div>

			<!-- Qué Ganas -->
			<div class="space-y-12 reveal-stagger">
				<h2 class="text-3xl md:text-4xl font-black text-center mb-12 tracking-wide text-transparent bg-clip-text bg-gradient-to-r from-white to-[var(--theme-color-primary)] drop-shadow-sm" style="font-family: var(--font-display);">
					¿Por qué deberías unirte?
				</h2>

				<!-- Item 1 -->
				<div>
					<h3 class="text-lg text-slate-200 mb-3 font-semibold">Desarrollo de Ideas y Validación de MVPs</h3>
					<div class="glow-card flex flex-col md:flex-row items-center gap-6 p-6 md:p-8">
						<div class="flex-1 md:border-r border-white/10 md:pr-8 text-center md:text-left mb-6 md:mb-0">
							<p class="text-slate-300 font-light italic">
								Diseña y valida soluciones a problemas reales. Estructura tu proyecto desde cero trabajando en equipo y utilizando metodologías ágiles
							</p>
						</div>
						<div class="flex flex-col items-center justify-center text-center shrink-0 w-32">
							<svg class="w-10 h-10 mb-3 text-[var(--theme-color-primary)]" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
								<!-- Rays -->
								<path d="M2 8h3M19 8h3M4.9 0.9l2.2 2.2M19.1 0.9l-2.2 2.2M4.9 15.1l2.2-2.2M19.1 15.1l-2.2-2.2" />
								<!-- Bulb outline -->
								<path d="M9.5 17c0-4-2-5-2-9a4.5 4.5 0 119 0c0 4-2 5-2 9" />
								<!-- Highlight -->
								<path d="M10 5c-1 1-1.5 2-1.5 3.5" />
								<!-- Base Rounded Rectangle -->
								<rect x="9" y="17" width="6" height="2.5" rx="1.25" />
								<!-- Bottom Chevron -->
								<path d="M10.5 20.5v.5l1.5 1.5l1.5-1.5v-.5" />
							</svg>
							<span class="text-sm font-semibold text-white">Desarrollo de ideas</span>
						</div>
					</div>
				</div>

				<!-- Item 2 -->
				<div>
					<h3 class="text-lg text-slate-200 mb-3 font-semibold">Certificación Oficial con Respaldo Institucional</h3>
					<div class="glow-card flex flex-col md:flex-row items-center gap-6 p-6 md:p-8">
						<div class="flex flex-col items-center justify-center text-center shrink-0 w-32 md:border-r border-white/10 md:pr-8 mb-6 md:mb-0">
							<svg class="w-10 h-10 mb-3 text-[var(--theme-color-secondary)]" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
								<!-- Document Outline -->
								<path d="M9 10V5a2 2 0 012-2h4l4 4v11a2 2 0 01-2 2h-4.5" />
								<!-- Fold inner lines -->
								<path d="M15 3v4h4" />
								<!-- Seal Circle -->
								<circle cx="9" cy="13.5" r="3.5" />
								<!-- Ribbon Tails -->
								<path d="M6.5 16l-1 5 3.5-1.5 3.5 1.5-1-5" />
								<!-- Text Lines -->
								<path d="M14 11h3M13 14h5M14 17h3" />
							</svg>
							<span class="text-sm font-semibold text-white leading-tight">Certificación oficial</span>
						</div>
						<div class="flex-1 text-center md:text-left">
							<p class="text-slate-300 font-light italic">
								Potencia tu perfil profesional. Obtén un certificado oficial respaldado por la universidad que valida tus horas y competencias técnicas.
							</p>
						</div>
					</div>
				</div>

				<!-- Item 3 -->
				<div>
					<h3 class="text-lg text-slate-200 mb-3 font-semibold">Mentorías Reales y Acceso a Expertos (Networking)</h3>
					<div class="glow-card flex flex-col md:flex-row items-center gap-6 p-6 md:p-8">
						<div class="flex-1 md:border-r border-white/10 md:pr-8 text-center md:text-left mb-6 md:mb-0">
							<p class="text-slate-300 font-light italic">
								Conéctate con expertos de la industria. Recibe feedback estratégico en sesiones exclusivas de IA, emprendimiento y diseño de soluciones.
							</p>
						</div>
						<div class="flex flex-col items-center justify-center text-center shrink-0 w-32">
							<svg class="w-10 h-10 mb-3 text-[var(--theme-color-primary)]" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
								<!-- Person -->
								<circle cx="10.5" cy="11.5" r="3" />
								<path d="M5 21a5.5 5.5 0 0111 0" />
								
								<!-- Board -->
								<!-- Left edge stops at y=9.5 -->
								<path d="M13 9.5V7a2 2 0 012-2h4a2 2 0 012 2v8a2 2 0 01-2 2h-4" />
								<path d="M16 9h2" />
								
								<!-- Pole -->
								<path d="M17 17v4" />
								<path d="M16.5 21h1" />
							</svg>
							<span class="text-sm font-semibold text-white">Mentorías reales</span>
						</div>
					</div>
				</div>

				<!-- Item 4 -->
				<div>
					<h3 class="text-lg text-slate-200 mb-3 font-semibold">Premios Financieros y Visibilidad</h3>
					<div class="glow-card flex flex-col md:flex-row items-center gap-6 p-6 md:p-8">
						<div class="flex flex-col items-center justify-center text-center shrink-0 w-32 md:border-r border-white/10 md:pr-8 mb-6 md:mb-0">
							<svg class="w-10 h-10 mb-3 text-[var(--theme-color-secondary)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" d="M9 14h6v8H9z" />
								<path stroke-linecap="round" stroke-linejoin="round" d="M4 17h5v5H4z" />
								<path stroke-linecap="round" stroke-linejoin="round" d="M15 19h5v3h-5z" />
								<path stroke-linecap="round" stroke-linejoin="round" d="M12 10v4" />
								<path stroke-linecap="round" stroke-linejoin="round" d="M10 14h4" />
								<path stroke-linecap="round" stroke-linejoin="round" d="M7 2h10v3c0 2.8-2.2 5-5 5s-5-2.2-5-5V2z" />
								<path stroke-linecap="round" stroke-linejoin="round" d="M7 3H5a2 2 0 000 4h2m10-4h2a2 2 0 010 4h-2" />
							</svg>
							<span class="text-sm font-semibold text-white leading-tight">Premios y visibilidad</span>
						</div>
						<div class="flex-1 text-center md:text-left">
							<p class="text-slate-300 font-light italic">
								Impulsa tu proyecto al siguiente nivel. Compite por premios en efectivo, herramientas tecnológicas y el interés de incubadoras clave.
							</p>
						</div>
					</div>
				</div>

			</div>
		</div>
	</section>

	<style>
		/* ===== GLOW CARD SYSTEM ===== */
		.glow-card {
			position: relative;
			border-radius: 1.25rem;
			background: linear-gradient(
				135deg,
				rgba(255, 255, 255, 0.06),
				rgba(255, 255, 255, 0.02)
			);
			border: 1px solid rgba(255, 255, 255, 0.08);
			padding: 1.75rem;
			overflow: hidden;
			transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
			backdrop-filter: blur(10px);
		}
		/* Top shimmer line */
		.glow-card::before {
			content: "";
			position: absolute;
			top: 0;
			left: 0;
			right: 0;
			height: 1px;
			background: linear-gradient(
				90deg,
				transparent,
				var(--theme-color-primary),
				var(--theme-color-secondary),
				transparent
			);
			opacity: 0.5;
			transition: opacity 0.5s ease;
		}
		/* Inner corner glow */
		.glow-card::after {
			content: "";
			position: absolute;
			top: -50%;
			left: -50%;
			width: 200%;
			height: 200%;
			background: radial-gradient(
				circle at 30% 30%,
				var(--theme-color-glow),
				transparent 50%
			);
			opacity: 0;
			transition: opacity 0.5s ease;
			pointer-events: none;
		}
		.glow-card:hover {
			border-color: var(--theme-color-primary);
			background: linear-gradient(
				135deg,
				rgba(255, 255, 255, 0.1),
				rgba(255, 255, 255, 0.04)
			);
			transform: translateY(-4px);
			box-shadow:
				0 0 30px var(--theme-color-glow),
				0 20px 40px rgba(0, 0, 0, 0.4);
		}
		.glow-card:hover::before {
			opacity: 1;
		}
		.glow-card:hover::after {
			opacity: 1;
		}
	</style>
</Layout>

<style>
	.hero-orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(120px);
	}
	.hero-orb--purple {
		width: 700px;
		height: 700px;
		top: -300px;
		left: 50%;
		transform: translateX(-50%);
		background: radial-gradient(circle, var(--theme-color-primary), transparent 65%);
		opacity: 0.25;
		animation: orb-float 24s ease-in-out infinite;
		transition: background 0.5s ease;
	}
	.hero-orb--blue {
		width: 500px;
		height: 500px;
		bottom: -150px;
		left: -150px;
		background: radial-gradient(circle, var(--theme-color-secondary), transparent 65%);
		opacity: 0.15;
		animation: orb-float 24s ease-in-out infinite;
		animation-delay: -3s;
		transition: background 0.5s ease;
	}
	.hero-orb--pink {
		width: 400px;
		height: 400px;
		bottom: -50px;
		right: -80px;
		background: radial-gradient(circle, var(--theme-color-primary), transparent 65%);
		opacity: 0.18;
		animation: orb-float 24s ease-in-out infinite;
		animation-delay: -5s;
		transition: background 0.5s ease;
	}
	/* Rotating ring decoration */
	.hero-ring {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 600px;
		height: 600px;
		border-radius: 50%;
		border: 1px solid rgba(192, 132, 252, 0.08);
		animation: spin-ring 90s linear infinite;
		pointer-events: none;
	}
	.hero-ring::before {
		content: "";
		position: absolute;
		top: -2px;
		left: 50%;
		width: 4px;
		height: 4px;
		border-radius: 50%;
		background: #c084fc;
		box-shadow: 0 0 12px rgba(192, 132, 252, 0.6);
	}
	@keyframes spin-ring {
		from { transform: translate(-50%, -50%) rotate(0deg); }
		to { transform: translate(-50%, -50%) rotate(360deg); }
	}
	.hero-grid {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
		background-size: 60px 60px;
		mask-image: radial-gradient(
			ellipse at center,
			black 30%,
			transparent 70%
		);
	}
	@keyframes orb-float {
		0%, 100% { transform: translateY(0px) translateX(-50%); }
		50% { transform: translateY(-30px) translateX(-50%); }
	}
</style>
