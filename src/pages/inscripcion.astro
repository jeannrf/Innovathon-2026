---
import Layout from "../layouts/Layout.astro";

// Generar array para 5 miembros máximo (0 es líder/individual)
const maxMembers = 5;
const membersArray = Array.from({ length: maxMembers }, (_, i) => i);
---

<Layout title="Inscripción | Innovathon 2026">
	<!-- Hero y Formulario -->
	<section class="relative pt-20 pb-12 overflow-hidden min-h-screen">
		<!-- Ambient orbs -->
		<div class="hero-orb hero-orb--purple"></div>
		<div class="hero-orb hero-orb--blue"></div>
		<div class="hero-orb hero-orb--pink"></div>
		<!-- Radial ring decoration -->
		<div class="hero-ring"></div>
		<!-- Grid pattern -->
		<div class="hero-grid"></div>

		<div class="container-custom relative z-10 max-w-5xl">
			<div class="text-center mb-6">
				<h1 class="text-4xl md:text-5xl font-light mb-4 text-white tracking-tight" style="font-family: var(--font-display);">
					Registro de Participantes
				</h1>
				<p class="text-slate-400 text-lg leading-relaxed max-w-2xl mx-auto">
					Completa tu información para asegurar tu lugar en la Innovathon. Puedes participar de forma individual o inscribir a tu equipo completo.
				</p>
			</div>

			<div class="glow-card relative p-6 md:p-10 shadow-2xl overflow-hidden">
				<div class="absolute -top-1/2 -left-1/4 w-96 h-96 bg-[#c084fc]/15 rounded-full blur-[100px] animate-float pointer-events-none"></div>
				<div class="absolute -bottom-1/2 -right-1/4 w-96 h-96 bg-[#818cf8]/15 rounded-full blur-[100px] animate-float-delayed pointer-events-none"></div>
				
				<div class="relative z-10">
					<form id="registration-form" class="space-y-12">
					
					<!-- 1. Modalidad -->
					<div class="space-y-6">
						<div class="border-b border-white/5 pb-4">
							<h3 class="text-xl font-medium text-white flex items-center gap-3">
								<span class="flex items-center justify-center w-8 h-8 rounded-full bg-indigo-500/20 text-indigo-400 text-sm font-bold">1</span>
								Modalidad de Participación
							</h3>
						</div>
						
						<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
							<label class="relative cursor-pointer group">
								<input type="radio" name="modalidad" value="individual" class="peer sr-only" checked />
								<div class="p-5 rounded-xl border border-white/10 bg-white/5 transition-all duration-200 peer-checked:border-[#c084fc] peer-checked:bg-[#c084fc]/10 hover:border-white/20">
									<div class="flex items-center justify-between mb-1">
										<h4 class="text-lg font-semibold text-white">Individual</h4>
									</div>
									<p class="text-sm text-slate-400">Te asignaremos a un equipo multidisciplinario.</p>
								</div>
							</label>

							<label class="relative cursor-pointer group">
								<input type="radio" name="modalidad" value="equipo" class="peer sr-only" />
								<div class="p-5 rounded-xl border border-white/10 bg-white/5 transition-all duration-200 peer-checked:border-[#c084fc] peer-checked:bg-[#c084fc]/10 hover:border-white/20">
									<div class="flex items-center justify-between mb-1">
										<h4 class="text-lg font-semibold text-white">Con Equipo</h4>
									</div>
									<p class="text-sm text-slate-400">Ya tengo un equipo armado (de 2 a 5 miembros).</p>
								</div>
							</label>
						</div>
					</div>

					<!-- 2. Datos del Equipo (Solo visible si es equipo) -->
					<div id="section-team-data" class="hidden space-y-6">
						<div class="border-b border-white/5 pb-4">
							<h3 class="text-xl font-medium text-white flex items-center gap-3">
								<span class="flex items-center justify-center w-8 h-8 rounded-full bg-sky-500/20 text-sky-400 text-sm font-bold">2</span>
								Información del Equipo
							</h3>
						</div>
						
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
							<div class="form-group">
								<label for="teamName" class="form-label">Nombre del Equipo *</label>
								<input type="text" id="teamName" name="teamName" class="form-input" placeholder="Ej. Innovators 3000" />
							</div>

							<div class="form-group">
								<label for="teamCategory" class="form-label">Categoría del Proyecto *</label>
								<select id="teamCategory" name="teamCategory" class="form-select appearance-none">
									<option value="" disabled selected>Selecciona una categoría...</option>
									<option value="mineria">Minería</option>
									<option value="logistica">Logística y transporte</option>
									<option value="educacion">Educación</option>
									<option value="ecommerce">E-commerce</option>
								</select>
							</div>

							<div class="form-group md:col-span-2">
								<label for="teamIdea" class="form-label">Idea de Proyecto *</label>
								<textarea id="teamIdea" name="teamIdea" rows="2" class="form-input resize-none" placeholder="Describe brevemente la idea o problema que resolverán..."></textarea>
							</div>

							<div class="form-group md:col-span-2">
								<label for="teamToolsSelect" class="form-label">Herramientas tecnológicas a usar (Agrega varias)</label>
								<select id="teamToolsSelect" class="form-select appearance-none mb-3">
									<option value="" disabled selected>Selecciona una herramienta para añadirla...</option>
									<option value="React/Next.js">React / Next.js</option>
									<option value="Python/Django">Python / Django / FastAPI</option>
									<option value="Node.js">Node.js</option>
									<option value="TensorFlow/PyTorch">TensorFlow / PyTorch</option>
									<option value="AWS/GCP/Azure">Cloud (AWS/GCP/Azure)</option>
									<option value="Figma">Figma</option>
									<option value="Arduino/Raspberry">Arduino / Raspberry Pi</option>
									<option value="Otra">Otra</option>
								</select>
								<!-- Contenedor de Badges para Herramientas -->
								<div id="teamToolsContainer" class="flex flex-wrap gap-2 min-h-[2rem]">
									<!-- Badges dinámicos irán aquí -->
								</div>
								<input type="hidden" name="teamTools" id="teamToolsHidden" />
							</div>

							<div class="form-group md:col-span-2 mt-4">
								<label class="form-label mb-2 block">Cantidad de Miembros *</label>
								<div class="flex gap-4">
									<label class="flex items-center gap-2 cursor-pointer">
										<input type="radio" name="memberCount" value="2" class="form-radio text-[#c084fc]" />
										<span class="text-white">2 Miembros</span>
									</label>
									<label class="flex items-center gap-2 cursor-pointer">
										<input type="radio" name="memberCount" value="3" class="form-radio text-[#c084fc]" checked />
										<span class="text-white">3 Miembros</span>
									</label>
									<label class="flex items-center gap-2 cursor-pointer">
										<input type="radio" name="memberCount" value="4" class="form-radio text-[#c084fc]" />
										<span class="text-white">4 Miembros</span>
									</label>
									<label class="flex items-center gap-2 cursor-pointer">
										<input type="radio" name="memberCount" value="5" class="form-radio text-[#c084fc]" />
										<span class="text-white">5 Miembros</span>
									</label>
								</div>
							</div>
						</div>
					</div>

					<!-- 3. Datos de Participantes -->
					<div class="space-y-6">
						<div class="border-b border-white/5 pb-4 flex flex-col md:flex-row md:items-center justify-between gap-4">
							<h3 class="text-xl font-medium text-white flex items-center gap-3">
								<span id="step-number-members" class="flex items-center justify-center w-8 h-8 rounded-full bg-indigo-500/20 text-indigo-400 text-sm font-bold">2</span>
								<span id="members-section-title">Datos Personales</span>
							</h3>
							
							<!-- Tabs de Miembros (Oculto en individual) -->
							<div id="member-tabs" class="hidden flex-wrap gap-2">
								{membersArray.map((i) => (
									<button 
										type="button" 
										class={`member-tab px-4 py-2 rounded-lg text-sm font-medium transition-colors border ${i === 0 ? 'bg-[#c084fc]/20 text-[#c084fc] border-[#c084fc]/30' : 'bg-white/5 text-slate-400 border-transparent hover:bg-white/10'} ${i > 2 ? 'hidden' : ''}`}
										data-target={i}
										id={`tab-${i}`}
									>
										{i === 0 ? 'Líder' : `Miembro ${i + 1}`}
									</button>
								))}
							</div>
						</div>

						<div class="relative">
							{membersArray.map((i) => (
								<div class={`member-fieldset ${i !== 0 ? 'hidden' : ''}`} id={`member-form-${i}`}>
									<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
										<div class="form-group">
											<label class="form-label">Nombres *</label>
											<input type="text" name={`nombres_${i}`} class="form-input" placeholder="Nombres completos" />
										</div>
										<div class="form-group">
											<label class="form-label">Apellidos *</label>
											<input type="text" name={`apellidos_${i}`} class="form-input" placeholder="Apellidos completos" />
										</div>
										<div class="form-group">
											<label class="form-label">DNI / CE *</label>
											<input type="text" name={`dni_${i}`} class="form-input" placeholder="Número de documento" />
										</div>
										<div class="form-group">
											<label class="form-label">Edad *</label>
											<input type="number" name={`edad_${i}`} min="16" max="99" class="form-input" placeholder="Edad" />
										</div>
										<div class="form-group md:col-span-2">
											<label class="form-label">Correo Electrónico *</label>
											<input type="email" name={`correo_${i}`} class="form-input" placeholder="correo@ejemplo.com" />
										</div>
										<div class="form-group md:col-span-2">
											<label class="form-label">Número de Teléfono (WhatsApp) *</label>
											<input type="tel" name={`telefono_${i}`} class="form-input" placeholder="+51 999 999 999" />
										</div>
										<div class="form-group md:col-span-2">
											<label class="form-label">Universidad / Institución *</label>
											<input type="text" name={`universidad_${i}`} class="form-input" placeholder="Ej. Universidad Nacional de Ingeniería" />
										</div>
										<div class="form-group md:col-span-2">
											<label class="form-label">Especialidad / Rol principal *</label>
											<select name={`especialidad_${i}`} class="form-select appearance-none">
												<option value="" disabled selected>Selecciona una especialidad...</option>
												<option value="desarrollo">Desarrollo de Software / Programación</option>
												<option value="data">Ciencia de Datos / IA</option>
												<option value="uxui">Diseño UX/UI</option>
												<option value="negocios">Negocios y Marketing</option>
												<option value="hardware">Ingeniería / Hardware</option>
												<option value="otros">Otros</option>
											</select>
										</div>
										
										<!-- Skills: Solo para Individual (i === 0) y cuando está en modo individual -->
										{i === 0 && (
											<div id="individual-skills-wrapper" class="form-group md:col-span-2">
												<label class="form-label">Tus Skills (Agrega varias para emparejarte mejor) *</label>
												<select id="individualSkillsSelect" class="form-select appearance-none mb-3">
													<option value="" disabled selected>Selecciona un skill para añadirlo...</option>
													<option value="Frontend">Frontend (HTML/CSS/JS/React)</option>
													<option value="Backend">Backend (Node/Python/Java)</option>
													<option value="Mobile">Mobile App Dev</option>
													<option value="Machine Learning">Machine Learning</option>
													<option value="UI/UX">Diseño UI/UX</option>
													<option value="Pitching">Pitching & Presentaciones</option>
													<option value="Gestión de Proyectos">Gestión de Proyectos</option>
												</select>
												<div id="individualSkillsContainer" class="flex flex-wrap gap-2 min-h-[2rem]">
													<!-- Badges dinámicos -->
												</div>
												<input type="hidden" name="individualSkills" id="individualSkillsHidden" />
											</div>
										)}

										<div class="form-group md:col-span-2">
											<label class="form-label">Cuéntame algo de ti</label>
											<textarea name={`about_${i}`} rows="3" class="form-input resize-none" placeholder="Tus hobbies, intereses, motivación para participar..."></textarea>
										</div>
									</div>
								</div>
							))}
						</div>
					</div>

					<!-- Submit -->
					<div class="pt-8 border-t border-white/5 flex flex-col items-center">
						<button type="submit" class="group relative w-full md:w-auto px-12 py-4 rounded-xl font-semibold text-white overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-[0_0_40px_rgba(192,132,252,0.3)] text-lg">
							<span class="absolute inset-0 bg-gradient-to-r from-[#c084fc] to-[#818cf8] opacity-80 group-hover:opacity-100 transition-opacity"></span>
							<span class="relative z-10 flex items-center justify-center gap-2">
								Completar Inscripción
							</span>
						</button>
						<p class="text-slate-500 text-sm mt-4 text-center">
							Al inscribirte aceptas los <a href="#" class="text-indigo-400 hover:underline">términos y condiciones</a> del evento.
						</p>
					</div>
					</form>
				</div>

				<!-- Success Message -->
				<div id="success-message" class="hidden py-16 text-center relative z-10">
					<div class="w-24 h-24 mx-auto bg-green-500/10 text-green-500 rounded-full flex items-center justify-center mb-6">
						<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
					</div>
					<h3 class="text-3xl font-semibold text-white mb-4">¡Inscripción Exitosa!</h3>
					<p class="text-slate-400 text-lg mb-8 max-w-lg mx-auto">
						Hemos recibido los datos correctamente. Revisa tu bandeja de entrada en las próximas horas para confirmar tu participación.
					</p>
					<a href="/" class="inline-flex px-8 py-3 rounded-lg border border-white/10 text-white hover:bg-white/5 transition-colors">
						Volver al inicio
					</a>
				</div>
			</div>
		</div>
	</section>

	<style>
		/* ===== GLOW CARD & ANIMATIONS (from index.astro) ===== */
		.glow-card {
			position: relative;
			border-radius: 1.25rem;
			background: linear-gradient(135deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02));
			border: 1px solid rgba(255, 255, 255, 0.1);
			overflow: hidden;
			transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
			backdrop-filter: blur(10px);
		}
		.glow-card::before {
			content: "";
			position: absolute;
			top: 0; left: 0; right: 0;
			height: 1px;
			background: linear-gradient(90deg, transparent, rgba(192, 132, 252, 0.6), rgba(129, 140, 248, 0.6), rgba(56, 189, 248, 0.6), transparent);
			opacity: 0.5;
			transition: opacity 0.5s ease;
		}
		.glow-card::after {
			content: "";
			position: absolute;
			top: -50%; left: -50%; width: 200%; height: 200%;
			background: radial-gradient(circle at 30% 30%, rgba(192, 132, 252, 0.08), transparent 50%);
			opacity: 0;
			transition: opacity 0.5s ease;
			pointer-events: none;
		}

		.hero-orb {
			position: absolute;
			border-radius: 50%;
			filter: blur(120px);
			animation: orb-float 24s ease-in-out infinite;
			pointer-events: none;
		}
		.hero-orb--purple {
			width: 700px; height: 700px;
			background: radial-gradient(circle, rgba(192, 132, 252, 0.4), transparent 65%);
			top: -300px; left: 50%;
			transform: translateX(-50%);
		}
		.hero-orb--blue {
			width: 500px; height: 500px;
			background: radial-gradient(circle, rgba(56, 189, 248, 0.2), transparent 65%);
			bottom: -150px; left: -150px;
			animation-delay: -3s;
		}
		.hero-orb--pink {
			width: 400px; height: 400px;
			background: radial-gradient(circle, rgba(129, 140, 248, 0.25), transparent 65%);
			bottom: -50px; right: -80px;
			animation-delay: -5s;
		}
		@keyframes orb-float {
			0%, 100% { transform: translateY(0px) translateX(-50%); }
			50% { transform: translateY(-30px) translateX(-50%); }
		}
		
		.hero-ring {
			position: absolute;
			top: 50%; left: 50%; transform: translate(-50%, -50%);
			width: 600px; height: 600px;
			border-radius: 50%;
			border: 1px solid rgba(192, 132, 252, 0.08);
			animation: spin-ring 90s linear infinite;
			pointer-events: none;
		}
		.hero-ring::before {
			content: ""; position: absolute;
			top: -2px; left: 50%; width: 4px; height: 4px;
			border-radius: 50%; background: #c084fc;
			box-shadow: 0 0 12px rgba(192, 132, 252, 0.6);
		}
		@keyframes spin-ring {
			from { transform: translate(-50%, -50%) rotate(0deg); }
			to { transform: translate(-50%, -50%) rotate(360deg); }
		}
		
		.hero-grid {
			position: absolute; inset: 0;
			background-image: linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
			background-size: 60px 60px;
			mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
			pointer-events: none;
		}

		.animate-float { animation: float-simple 12s ease-in-out infinite; }
		.animate-float-delayed { animation: float-simple 12s ease-in-out infinite; animation-delay: -6s; }
		@keyframes float-simple {
			0%, 100% { transform: translateY(0); }
			50% { transform: translateY(-30px); }
		}

		.form-group {
			display: flex;
			flex-direction: column;
			gap: 0.5rem;
		}
		.form-label {
			font-size: 0.875rem;
			font-weight: 500;
			color: rgba(255, 255, 255, 0.7);
		}
		.form-input, .form-select {
			width: 100%;
			background-color: rgba(255, 255, 255, 0.03);
			border: 1px solid rgba(255, 255, 255, 0.1);
			border-radius: 0.75rem;
			padding: 0.875rem 1.25rem;
			color: white;
			font-size: 0.95rem;
			transition: all 0.2s;
		}
		.form-input::placeholder {
			color: rgba(255, 255, 255, 0.3);
		}
		.form-input:focus, .form-select:focus {
			outline: none;
			border-color: #818cf8;
			background-color: rgba(255, 255, 255, 0.06);
			box-shadow: 0 0 0 1px #818cf8, 0 0 20px rgba(192, 132, 252, 0.3), 0 0 20px rgba(56, 189, 248, 0.3);
		}
		.form-select {
			appearance: none;
			background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%23ffffff' stroke-opacity='0.5' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
			background-position: right 1.25rem center;
			background-repeat: no-repeat;
			background-size: 1.5em 1.5em;
			padding-right: 3rem;
		}
		.form-select option {
			background-color: #121212;
			color: white;
		}
		
			/* Radio buttons customs */
		.form-radio {
			appearance: none;
			width: 1.25rem;
			height: 1.25rem;
			border: 2px solid rgba(255, 255, 255, 0.2);
			border-radius: 50%;
			margin: 0;
			display: grid;
			place-content: center;
			transition: all 0.2s;
			cursor: pointer;
		}
		.form-radio::before {
			content: "";
			width: 0.65rem;
			height: 0.65rem;
			border-radius: 50%;
			transform: scale(0);
			transition: 120ms transform ease-in-out;
			box-shadow: inset 1em 1em currentColor;
		}
		.form-radio:checked {
			border-color: currentColor;
		}
		.form-radio:checked::before {
			transform: scale(1);
		}

		/* Ocultar flechas en campos numéricos (como edad) */
		input[type="number"]::-webkit-outer-spin-button,
		input[type="number"]::-webkit-inner-spin-button {
			-webkit-appearance: none;
			margin: 0;
		}
		input[type="number"] {
			-moz-appearance: textfield;
		}
	</style>

	<script>
		document.addEventListener('DOMContentLoaded', initForm);
		document.addEventListener('astro:page-load', () => {
			const form = document.getElementById('registration-form');
			if (!form) return;
			initForm();
		});

		function setupCustomSelects() {
			/** @type {NodeListOf<HTMLSelectElement>} */
			const selects = document.querySelectorAll('select.form-select');
			selects.forEach(select => {
				if (select.dataset.customized) return;
				select.dataset.customized = 'true';
				
				// Capturar el atributo de scope de Astro (ej. data-astro-cid-j7pvhlwa)
				const astroAttr = Array.from(select.attributes).find(attr => attr.name.startsWith('data-astro-cid-'))?.name;
				
				// Hide native select but keep focusable/submittable
				select.style.position = 'absolute';
				select.style.opacity = '0';
				select.style.pointerEvents = 'none';
				select.style.height = '0';
				
				if (!select.parentNode) return;
				
				const wrapper = document.createElement('div');
				wrapper.className = 'custom-select-container relative w-full';
				if (astroAttr) wrapper.setAttribute(astroAttr, '');
				select.parentNode.insertBefore(wrapper, select);
				wrapper.appendChild(select);
				
				const trigger = document.createElement('div');
				trigger.className = 'form-select cursor-pointer flex items-center select-none';
				if (astroAttr) trigger.setAttribute(astroAttr, '');
				trigger.innerHTML = `<span class="truncate text-slate-300 pointer-events-none" ${astroAttr ? astroAttr+'=""' : ''}>${select.options[select.selectedIndex]?.text || ''}</span>`;
				wrapper.appendChild(trigger);
				
				const dropdown = document.createElement('div');
				dropdown.className = 'absolute z-50 w-full mt-2 bg-[#121212]/95 backdrop-blur-xl border border-[#c084fc]/30 rounded-xl shadow-[0_0_40px_rgba(192,132,252,0.2)] overflow-hidden hidden opacity-0 transition-opacity duration-200';
				if (astroAttr) dropdown.setAttribute(astroAttr, '');
				
				Array.from(select.options).forEach((opt) => {
					if (opt.disabled) return;
					const item = document.createElement('div');
					if (astroAttr) item.setAttribute(astroAttr, '');
					item.className = 'px-4 py-3 cursor-pointer text-slate-300 hover:text-white hover:bg-gradient-to-r hover:from-[#c084fc]/20 hover:to-[#818cf8]/20 transition-colors border-b border-white/5 last:border-0';
					item.textContent = opt.text;
					item.addEventListener('click', () => {
						select.value = opt.value;
						select.dispatchEvent(new Event('change'));
						closeDropdown();
					});
					dropdown.appendChild(item);
				});
				wrapper.appendChild(dropdown);
				
				const toggleDropdown = (e) => {
					e.stopPropagation();
					const isOpen = !dropdown.classList.contains('hidden');
					document.querySelectorAll('.custom-select-container > .absolute').forEach(d => {
						d.classList.add('hidden');
						d.classList.replace('opacity-100', 'opacity-0');
					});
					if (!isOpen) {
						dropdown.classList.remove('hidden');
						setTimeout(() => dropdown.classList.replace('opacity-0', 'opacity-100'), 10);
					}
				};
				
				trigger.addEventListener('click', toggleDropdown);
				
				const closeDropdown = () => {
					dropdown.classList.replace('opacity-100', 'opacity-0');
					setTimeout(() => dropdown.classList.add('hidden'), 200);
				};
				
				document.addEventListener('click', (e) => {
					if (!wrapper.contains(e.target)) closeDropdown();
				});

				select.addEventListener('change', () => {
					if (select.selectedIndex >= 0) {
						const span = trigger.querySelector('span');
						span.textContent = select.options[select.selectedIndex].text;
						if (select.options[select.selectedIndex].disabled) {
							span.classList.replace('text-white', 'text-slate-300');
						} else {
							span.classList.replace('text-slate-300', 'text-white');
						}
					}
				});
			});
		}

		function initForm() {
			setupCustomSelects();
			const form = document.getElementById('registration-form');
			if (!form) return;

			// Elements
			const modalidadRadios = document.querySelectorAll('input[name="modalidad"]');
			const teamSection = document.getElementById('section-team-data');
			const memberTabs = document.getElementById('member-tabs');
			const stepNumberMembers = document.getElementById('step-number-members');
			const membersSectionTitle = document.getElementById('members-section-title');
			const individualSkillsWrapper = document.getElementById('individual-skills-wrapper');
			
			const memberCountRadios = document.querySelectorAll('input[name="memberCount"]');
			const tabs = document.querySelectorAll('.member-tab');
			const fieldsets = document.querySelectorAll('.member-fieldset');

			let currentMode = 'individual';
			let currentCount = 3;

			// Required fields logic mapping (Frontend simulation)
			const setRequiredFields = (index, required) => {
				const fieldset = document.getElementById(`member-form-${index}`);
				if(!fieldset) return;
				const inputs = fieldset.querySelectorAll('input:not([type="hidden"]), select');
				inputs.forEach(input => {
					// 'about' and 'skills' are optional/handled separately if needed
					if(input.name.startsWith('about_')) return;
					if (required) input.setAttribute('required', 'true');
					else input.removeAttribute('required');
				});
			};

			// Initialize Required fields for Member 0
			setRequiredFields(0, true);

			// Modalidad Toggle
			modalidadRadios.forEach(radio => {
				radio.addEventListener('change', (e) => {
					currentMode = (e.target as HTMLInputElement).value;
					if (currentMode === 'equipo') {
						teamSection?.classList.remove('hidden');
						memberTabs?.classList.remove('hidden');
						memberTabs?.classList.add('flex');
						if (stepNumberMembers) { stepNumberMembers.textContent = '3'; stepNumberMembers.className = 'flex items-center justify-center w-8 h-8 rounded-full bg-[#c084fc]/20 text-[#c084fc] text-sm font-bold'; }
						if (membersSectionTitle) membersSectionTitle.textContent = 'Datos de los Integrantes';
						if (individualSkillsWrapper) individualSkillsWrapper.classList.add('hidden');
						
						// Require team fields
						document.getElementById('teamName')?.setAttribute('required', 'true');
						document.getElementById('teamCategory')?.setAttribute('required', 'true');
						document.getElementById('teamIdea')?.setAttribute('required', 'true');
						
						updateTabsVisibility();
					} else {
						teamSection?.classList.add('hidden');
						memberTabs?.classList.add('hidden');
						memberTabs?.classList.remove('flex');
						if (stepNumberMembers) { stepNumberMembers.textContent = '2'; stepNumberMembers.className = 'flex items-center justify-center w-8 h-8 rounded-full bg-[#c084fc]/20 text-[#c084fc] text-sm font-bold'; }
						if (membersSectionTitle) membersSectionTitle.textContent = 'Datos Personales';
						if (individualSkillsWrapper) individualSkillsWrapper.classList.remove('hidden');

						// Unrequire team fields
						document.getElementById('teamName')?.removeAttribute('required');
						document.getElementById('teamCategory')?.removeAttribute('required');
						document.getElementById('teamIdea')?.removeAttribute('required');

						// Reset to tab 0
						switchTab(0);
						// Disable required for members 1-4
						for(let i=1; i<=4; i++) setRequiredFields(i, false);
					}
				});
			});

			// Member Count Toggle
			memberCountRadios.forEach(radio => {
				radio.addEventListener('change', (e) => {
					currentCount = parseInt((e.target as HTMLInputElement).value);
					updateTabsVisibility();
				});
			});

			function updateTabsVisibility() {
				tabs.forEach((tab) => {
					const targetIndex = parseInt(tab.getAttribute('data-target') || '0');
					if (targetIndex < currentCount) {
						tab.classList.remove('hidden');
						setRequiredFields(targetIndex, true);
					} else {
						tab.classList.add('hidden');
						setRequiredFields(targetIndex, false);
					}
				});
				// If current tab is hidden, switch to 0
				const activeTab = document.querySelector('.member-tab:not(.bg-slate-800)');
				if (activeTab && parseInt(activeTab.getAttribute('data-target') || '0') >= currentCount) {
					switchTab(0);
				}
			}

			// Tab Switching
			tabs.forEach(tab => {
				tab.addEventListener('click', () => {
					const target = parseInt(tab.getAttribute('data-target') || '0');
					switchTab(target);
				});
			});

			function switchTab(index) {
				// Update tabs UI
				tabs.forEach(t => {
					const tIndex = parseInt(t.getAttribute('data-target') || '0');
					const isHidden = t.classList.contains('hidden') ? 'hidden' : '';
					if (tIndex === index) {
						t.className = `member-tab px-4 py-2 rounded-lg text-sm font-medium transition-colors border bg-[#c084fc]/20 text-[#c084fc] border-[#c084fc]/30 ${isHidden}`;
					} else {
						t.className = `member-tab px-4 py-2 rounded-lg text-sm font-medium transition-colors border bg-white/5 text-slate-400 border-transparent hover:bg-white/10 ${isHidden}`;
					}
				});

				// Update fieldsets
				fieldsets.forEach(fs => {
					if (parseInt(fs.getAttribute('id')?.split('-')[2] || '0') === index) {
						fs.classList.remove('hidden');
					} else {
						fs.classList.add('hidden');
					}
				});
			}

			// --- Badge Logic Generator ---
			function setupBadgeSelect(selectId, containerId, hiddenInputId) {
				const select = /** @type {HTMLSelectElement} */ (document.getElementById(selectId));
				const container = document.getElementById(containerId);
				const hiddenInput = /** @type {HTMLInputElement} */ (document.getElementById(hiddenInputId));
				/** @type {Set<string>} */ const items = new Set();

				if (!select || !container || !hiddenInput) return;

				const renderBadges = () => {
					container.innerHTML = '';
					items.forEach(item => {
						const badge = document.createElement('div');
						badge.className = 'inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-white/10 border border-white/10 text-sm text-slate-200';
						badge.innerHTML = `
							${item}
							<button type="button" class="text-slate-400 hover:text-white" data-item="${item}">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
							</button>
						`;
						badge.querySelector('button')?.addEventListener('click', (e) => {
							const targetItem = /** @type {HTMLElement} */ (e.currentTarget).getAttribute('data-item');
							if(targetItem) {
								items.delete(targetItem);
								hiddenInput.value = Array.from(items).join(',');
								renderBadges();
							}
						});
						container.appendChild(badge);
					});
				};

				select.addEventListener('change', () => {
					const val = select.value;
					if (val && !items.has(val)) {
						items.add(val);
						hiddenInput.value = Array.from(items).join(',');
						renderBadges();
					}
					select.value = ''; // reset
				});
			}

			setupBadgeSelect('teamToolsSelect', 'teamToolsContainer', 'teamToolsHidden');
			setupBadgeSelect('individualSkillsSelect', 'individualSkillsContainer', 'individualSkillsHidden');

			// Submit behavior
			form.addEventListener('submit', (e) => {
				e.preventDefault();
				form.classList.add('hidden');
				document.getElementById('success-message')?.classList.remove('hidden');
				window.scrollTo({ top: 0, behavior: 'smooth' });
			});
		}
	</script>
</Layout>
