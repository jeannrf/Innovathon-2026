---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Cómo Participar | Innovathon 2026">
	<div class="relative min-h-screen w-full overflow-hidden">
		<!-- Background Orbs and Grid (Visible on Scroll) -->
		<div class="absolute inset-0 pointer-events-none z-0">
			<div class="hero-orb hero-orb--primary"></div>
			<div class="hero-orb hero-orb--secondary"></div>
			<div class="page-grid"></div>
		</div>

		<!-- Hero Section -->
		<section class="relative pt-24 pb-12 overflow-hidden min-h-[40vh] flex items-center justify-center">
			<div class="container-custom relative z-10 max-w-5xl text-center reveal">
				<span class="section-label">Proceso y Requisitos</span>
				<h1 
					class="text-5xl md:text-7xl font-bold tracking-tight text-white mb-6 font-outfit"
				>
					¿Cómo puedo <span class="bg-gradient-to-r from-[var(--theme-color-primary)] to-[var(--theme-color-secondary)] bg-clip-text text-transparent transition-all duration-500">participar?</span>
				</h1>
				<p class="text-slate-400 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto font-light">
					Sigue esta guía paso a paso y asegura tu lugar en la Innovathon.
				</p>
			</div>
		</section>

		<div class="container-custom max-w-5xl pb-32 relative z-10 space-y-24">
			
			<!-- Requisitos Section -->
			<section class="reveal">
				<!-- Header with Left Accent Line -->
				<div class="flex flex-col gap-2 mb-8 border-b border-white/5 pb-4">
					<div class="flex items-center gap-3">
						<span class="w-1.5 h-8 rounded-full bg-[var(--theme-color-primary)]"></span>
						<h2 
							class="text-3xl md:text-4xl font-bold text-white tracking-tight font-outfit"
						>
							Requisitos
						</h2>
					</div>
					<p class="text-slate-400 text-sm ml-4">Asegúrate de cumplir con los siguientes puntos antes de iniciar el registro.</p>
				</div>

				<!-- Glassmorphism Card -->
				<div class="glow-card p-8 md:p-12 relative overflow-hidden">
					<div class="absolute -top-24 -right-24 w-48 h-48 bg-[var(--theme-color-glow)] rounded-full blur-[80px] pointer-events-none"></div>
					
					<ul class="space-y-8 font-light text-slate-300">
						<!-- Requisito 1: GraduationCap -->
						<li class="flex items-start gap-5">
							<span class="flex-shrink-0 w-12 h-12 rounded-xl bg-[var(--theme-color-primary)]/10 text-[var(--theme-color-primary)] flex items-center justify-center border border-[var(--theme-color-primary)]/20 shadow-[0_0_15px_rgba(255,255,255,0.02)]">
								<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.231-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 019.918 5.84m-19.836 0l.002.001.008.003A48.837 48.837 0 0112 12.751c6.586 0 12.43-2.588 15.658-6.756m0 0a50.57 50.57 0 012.658-.813M12 14.25v6.25m-6.75-6v-3.5m13.5 3.5v-3.5" />
								</svg>
							</span>
							<div>
								<strong class="text-white font-semibold text-lg block font-outfit mb-1">Estudiantes de Pregrado</strong>
								<p class="text-slate-400 text-sm md:text-base leading-relaxed">Estudiantes de pregrado matriculados en el periodo académico vigente (universidad, instituto o educación superior del Perú, pública o privada).</p>
							</div>
						</li>
						
						<!-- Requisito 2: Users -->
						<li class="flex items-start gap-5">
							<span class="flex-shrink-0 w-12 h-12 rounded-xl bg-[var(--theme-color-primary)]/10 text-[var(--theme-color-primary)] flex items-center justify-center border border-[var(--theme-color-primary)]/20 shadow-[0_0_15px_rgba(255,255,255,0.02)]">
								<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.109A12.318 12.318 0 019.374 21c-2.331 0-4.512-.645-6.374-1.766v-.109a12.318 12.318 0 015.625-1.763c2.33 0 4.51.645 6.374 1.766zm-3.125-9.878a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM15.75 7.5a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
								</svg>
							</span>
							<div>
								<strong class="text-white font-semibold text-lg block font-outfit mb-1">Equipos de exactamente 4 integrantes</strong>
								<p class="text-slate-400 text-sm md:text-base leading-relaxed">El grupo debe estar constituido por exactamente 4 participantes para las dinámicas y entregables grupales.</p>
							</div>
						</li>

						<!-- Requisito 3: Laptop/Terminal -->
						<li class="flex items-start gap-5">
							<span class="flex-shrink-0 w-12 h-12 rounded-xl bg-[var(--theme-color-primary)]/10 text-[var(--theme-color-primary)] flex items-center justify-center border border-[var(--theme-color-primary)]/20 shadow-[0_0_15px_rgba(255,255,255,0.02)]">
								<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
								</svg>
							</span>
							<div>
								<strong class="text-white font-semibold text-lg block font-outfit mb-1">Perfil TI Obligatorio</strong>
								<p class="text-slate-400 text-sm md:text-base leading-relaxed">Al menos un integrante del equipo debe pertenecer a una carrera relacionada a Tecnologías de la Información, Ciencias de la Computación o afines.</p>
							</div>
						</li>

						<!-- Requisito 4: Network -->
						<li class="flex items-start gap-5">
							<span class="flex-shrink-0 w-12 h-12 rounded-xl bg-[var(--theme-color-primary)]/10 text-[var(--theme-color-primary)] flex items-center justify-center border border-[var(--theme-color-primary)]/20 shadow-[0_0_15px_rgba(255,255,255,0.02)]">
								<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
									<rect x="16" y="16" width="6" height="6" rx="1" />
									<rect x="2" y="16" width="6" height="6" rx="1" />
									<rect x="9" y="2" width="6" height="6" rx="1" />
									<path d="M12 8v4M5 16v-2a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v2M12 12h.01" stroke-linecap="round" stroke-linejoin="round" />
								</svg>
							</span>
							<div>
								<strong class="text-white font-semibold text-lg block font-outfit mb-1">Diversidad Multidisciplinaria</strong>
								<p class="text-slate-400 text-sm md:text-base leading-relaxed">El equipo debe incluir participantes de al menos dos carreras distintas para asegurar diferentes perspectivas en la solución.</p>
							</div>
						</li>

						<!-- Requisito 5: Brain -->
						<li class="flex items-start gap-5">
							<span class="flex-shrink-0 w-12 h-12 rounded-xl bg-[var(--theme-color-primary)]/10 text-[var(--theme-color-primary)] flex items-center justify-center border border-[var(--theme-color-primary)]/20 shadow-[0_0_15px_rgba(255,255,255,0.02)]">
								<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" d="M12 18v3m0 0h.01m-0.01 0h-.01m0-3h.01M12 3a9 9 0 00-9 9c0 1.956.626 3.766 1.688 5.25C5.9 18.8 7.375 20.35 9 20.35h6c1.625 0 3.1-1.55 4.312-3.1A8.966 8.966 0 0021 12a9 9 0 00-9-9zm-1.5 5.25a1.5 1.5 0 113 0M9.75 14.25h4.5" />
								</svg>
							</span>
							<div>
								<strong class="text-white font-semibold text-lg block font-outfit mb-1">Idea Preliminar e IA</strong>
								<p class="text-slate-400 text-sm md:text-base leading-relaxed">Durante la inscripción, el equipo deberá presentar una idea preliminar del proyecto indicando qué herramientas y tecnologías de Inteligencia Artificial planean utilizar.</p>
							</div>
						</li>
					</ul>
				</div>
			</section>

			<!-- Reglas Section -->
			<section class="reveal">
				<!-- Header with Left Accent Line -->
				<div class="flex flex-col gap-2 mb-8 border-b border-white/5 pb-4">
					<div class="flex items-center gap-3">
						<span class="w-1.5 h-8 rounded-full bg-[var(--theme-color-primary)]"></span>
						<h2 
							class="text-3xl md:text-4xl font-bold text-white tracking-tight font-outfit"
						>
							Reglas
						</h2>
					</div>
					<p class="text-slate-400 text-sm ml-4">Normas fundamentales para garantizar un proceso justo y transparente.</p>
				</div>

				<!-- Reglas Card Destacada -->
				<div class="glow-card p-8 md:p-12 overflow-hidden">
					<div class="absolute -bottom-24 -left-24 w-48 h-48 bg-[var(--theme-color-glow)] rounded-full blur-[80px] pointer-events-none"></div>
					
					<div class="max-w-3xl mx-auto space-y-8 relative z-10">
						<ul class="space-y-5 text-gray-300 text-base md:text-lg font-light text-left">
							<li class="flex items-start gap-3">
								<span class="flex-shrink-0 w-5 h-5 rounded-full bg-[var(--theme-color-glow)] border border-[var(--theme-color-primary)]/30 flex items-center justify-center mt-1 text-[var(--theme-color-primary)]">
									<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
										<circle cx="12" cy="12" r="10" />
									</svg>
								</span>
								<div>
									Toda información ingresada tiene carácter de <strong>declaración jurada</strong>.
								</div>
							</li>
							<li class="flex items-start gap-3">
								<span class="flex-shrink-0 w-5 h-5 rounded-full bg-[var(--theme-color-glow)] border border-[var(--theme-color-primary)]/30 flex items-center justify-center mt-1 text-[var(--theme-color-primary)]">
									<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
										<circle cx="12" cy="12" r="10" />
									</svg>
								</span>
								<div>
									Los proyectos deben ser de <strong>creación original</strong> y no infringir propiedad intelectual.
								</div>
							</li>
							<li class="flex items-start gap-3">
								<span class="flex-shrink-0 w-5 h-5 rounded-full bg-[var(--theme-color-glow)] border border-[var(--theme-color-primary)]/30 flex items-center justify-center mt-1 text-[var(--theme-color-primary)]">
									<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
										<circle cx="12" cy="12" r="10" />
									</svg>
								</span>
								<div>
									Las soluciones deben enfocarse en <strong>IA aplicada a la sostenibilidad</strong> y alinearse a los ODS.
								</div>
							</li>
						</ul>
						
						<div class="pt-6 flex justify-center">
							<a 
								href="/docs/bases.pdf" 
								target="_blank"
								class="btn-animate-rgb inline-flex items-center gap-3 px-10 py-4 rounded-2xl font-semibold text-white text-lg cursor-pointer"
							>
								Ver Bases Completas
								<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
								</svg>
							</a>
						</div>
					</div>
				</div>
			</section>

			<!-- Guía de Registro Section -->
			<section class="reveal">
				<!-- Header with Left Accent Line -->
				<div class="flex flex-col gap-2 mb-8 border-b border-white/5 pb-4">
					<div class="flex items-center gap-3">
						<span class="w-1.5 h-8 rounded-full bg-[var(--theme-color-primary)]"></span>
						<h2 
							class="text-3xl md:text-4xl font-bold text-white tracking-tight font-outfit"
						>
							Guía de Registro
						</h2>
					</div>
					<p class="text-slate-400 text-sm ml-4">Mira nuestro videotutorial para guiarte paso a paso en el proceso de registro.</p>
				</div>

				<!-- Flujo Vertical: Video/GIF Tutorial Simulator -->
				<div class="space-y-8 max-w-3xl mx-auto">

					<!-- Video/GIF Slot -->
					<div class="space-y-4">
						<div class="flex items-center justify-between px-2">
							<span class="text-slate-300 text-sm font-semibold tracking-wider uppercase flex items-center gap-2">
								<span class="w-2.5 h-2.5 rounded-full bg-gradient-to-r from-[var(--theme-color-primary)] to-[var(--theme-color-secondary)]"></span>
								Tutorial de Inscripción: Guía Completa Paso a Paso
							</span>
							<span class="text-xs text-slate-500 font-mono">03:30</span>
						</div>
						
						<div class="tutorial-card group relative aspect-video w-full rounded-2xl overflow-hidden bg-white/5 border border-white/10 flex items-center justify-center cursor-pointer transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_0_25px_var(--theme-color-glow)]">
							<!-- Skeleton Lines / Mock UI -->
							<div class="absolute inset-0 flex flex-col justify-between p-6 opacity-25">
								<div class="flex justify-between items-center">
									<div class="flex items-center gap-3">
										<div class="w-8 h-8 rounded-full bg-white/20 animate-pulse"></div>
										<div class="w-32 h-4 rounded bg-white/20 animate-pulse"></div>
									</div>
									<div class="flex gap-2">
										<div class="w-4 h-4 rounded bg-white/20"></div>
										<div class="w-4 h-4 rounded bg-white/20"></div>
									</div>
								</div>
								<div class="space-y-3">
									<div class="w-3/4 h-3 rounded bg-white/20 animate-pulse"></div>
									<div class="w-1/2 h-3 rounded bg-white/20 animate-pulse"></div>
								</div>
							</div>
							<!-- Radial overlay -->
							<div class="absolute inset-0 bg-gradient-to-t from-slate-950/90 via-transparent to-transparent"></div>
							
							<!-- Play Button -->
							<div class="relative z-10 w-20 h-20 rounded-full bg-[var(--theme-color-glow)] border border-[var(--theme-color-primary)]/40 flex items-center justify-center text-white transition-all duration-300 group-hover:scale-110 group-hover:shadow-[0_0_35px_var(--theme-color-glow)]">
								<svg class="w-8 h-8 text-[var(--theme-color-primary)] ml-1 transition-colors group-hover:text-white" fill="currentColor" viewBox="0 0 24 24">
									<path d="M8 5v14l11-7z" />
								</svg>
							</div>
						</div>
					</div>

					<!-- Official link -->
					<div class="text-center pt-8">
						<p class="text-slate-400 text-sm font-light">
							Para resolver dudas y encontrar material de soporte oficial, visita la página oficial del evento: 
							<a 
								href="https://innovathon.uni.edu.pe/" 
								target="_blank" 
								class="text-[var(--theme-color-primary)] hover:underline font-semibold transition-colors inline-flex items-center gap-1.5"
							>
								innovathon.uni.edu.pe
								<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
								</svg>
							</a>
						</p>
					</div>
				</div>
			</section>

		</div>
	</div>
</Layout>

<style>
	/* ===== CSS LOCAL STYLES ===== */
	
	/* Hero Orbs (consistent with index.astro) */
	.hero-orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(120px);
		pointer-events: none;
	}
	.hero-orb--primary {
		width: 600px;
		height: 600px;
		top: -250px;
		left: 50%;
		transform: translateX(-50%);
		background: radial-gradient(circle, var(--theme-color-primary), transparent 65%);
		opacity: 0.2;
		animation: orb-float 20s ease-in-out infinite;
	}
	.hero-orb--secondary {
		width: 400px;
		height: 400px;
		bottom: -100px;
		left: 10%;
		background: radial-gradient(circle, var(--theme-color-secondary), transparent 65%);
		opacity: 0.12;
		animation: orb-float 24s ease-in-out infinite;
		animation-delay: -5s;
	}
	
	@keyframes orb-float {
		0%, 100% { transform: translateY(0px) translateX(0px); }
		50% { transform: translateY(-20px) translateX(15px); }
	}

	.page-grid {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
		background-size: 60px 60px;
		pointer-events: none;
	}

	/* Glow Card System */
	.glow-card {
		position: relative;
		border-radius: 1.5rem;
		background: linear-gradient(
			135deg,
			rgba(255, 255, 255, 0.04),
			rgba(255, 255, 255, 0.01)
		);
		border: 1px solid rgba(255, 255, 255, 0.08);
		overflow: hidden;
		transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
	}
	.glow-card::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent,
			var(--theme-color-primary),
			var(--theme-color-secondary),
			transparent
		);
		opacity: 0.4;
		transition: opacity 0.5s ease;
	}
	.glow-card:hover {
		border-color: rgba(255, 255, 255, 0.15);
		background: linear-gradient(
			135deg,
			rgba(255, 255, 255, 0.07),
			rgba(255, 255, 255, 0.02)
		);
		transform: translateY(-4px);
		box-shadow: 
			0 0 30px var(--theme-color-glow),
			0 20px 40px rgba(0, 0, 0, 0.3);
	}
	.glow-card:hover::before {
		opacity: 0.8;
	}

	/* Buttons styling */
	.btn-animate-rgb {
		position: relative;
		background: linear-gradient(to right, var(--theme-color-primary), var(--theme-color-secondary));
		transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		z-index: 1;
	}
	.btn-animate-rgb::before {
		content: '';
		position: absolute;
		inset: -2px;
		background: inherit;
		background-size: inherit;
		border-radius: inherit;
		filter: blur(12px);
		opacity: 0;
		z-index: -1;
		transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1), transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.btn-animate-rgb:hover {
		transform: scale(1.03);
	}
	.btn-animate-rgb:hover::before {
		opacity: 0.6;
		transform: scale(1.02);
	}

	/* Tutorial Cards (simulated videos) */
	.tutorial-card {
		box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);
		transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}
</style>
