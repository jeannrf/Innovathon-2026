---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Inicio">
	<!-- HERO -->
	<section
		class="relative overflow-hidden flex items-center justify-center"
		style="min-height: calc(100vh - 64px);"
	>
		<!-- Ambient orbs -->
		<div class="hero-orb hero-orb--purple"></div>
		<div class="hero-orb hero-orb--blue"></div>
		<div class="hero-orb hero-orb--pink"></div>
		<!-- Radial ring decoration -->
		<div class="hero-ring"></div>
		<!-- Grid pattern -->
		<div class="hero-grid"></div>

		<div class="container-custom text-center relative z-10 pb-16">
			<h1
				class="text-6xl md:text-8xl lg:text-9xl font-extralight tracking-tight mb-4 hero-title"
				style="font-family: var(--font-display);"
			>
				Innovathon
			</h1>
			<h2
				class="text-3xl md:text-5xl lg:text-6xl font-light tracking-tight mb-10 bg-gradient-to-r from-[var(--theme-color-primary)] to-[var(--theme-color-secondary)] bg-clip-text text-transparent transition-all duration-500"
				style="font-family: var(--font-display);"
			>
				"Launch with AI"
			</h2>
			<p
				class="text-lg md:text-xl text-slate-300/80 max-w-2xl mx-auto mb-14 leading-relaxed font-light"
			>
				Descubre el evento de innovación en la UNI donde tus ideas se
				transforman en impacto real mediante Inteligencia Artificial y
				metodologías ágiles.
			</p>

			<div class="flex flex-wrap justify-center gap-5">
				<a
					href="#"
					class="btn-animate-rgb px-8 py-3.5 rounded-xl font-semibold text-white cursor-pointer"
				>
					<span class="relative z-10 flex items-center gap-2">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
							><path
								d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
							></path><path
								d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.613.613l4.458-1.495A11.952 11.952 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.352 0-4.55-.764-6.324-2.057l-.44-.33-3.28 1.1 1.1-3.28-.33-.44A9.965 9.965 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"
							></path></svg
						>
						Canal de Whatsapp
					</span>
				</a>
				<a
					href="#"
					class="group relative px-8 py-3.5 rounded-xl font-semibold text-white border border-white/20 hover:border-[#818cf8]/50 transition-all duration-300 hover:scale-105 hover:shadow-[0_0_40px_rgba(129,140,248,0.2)] bg-white/5 hover:bg-white/10 backdrop-blur-sm cursor-pointer"
				>
					<span class="flex items-center gap-2">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
							><path
								d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286z"
							></path></svg
						>
						Canal de Discord
					</span>
				</a>
			</div>
		</div>
	</section>

	<!-- HIGHLIGHTS -->
	<section class="py-16 relative z-10">
		<div class="container-custom">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 reveal-stagger">
				<div class="glow-card text-center cursor-pointer">
					<div class="highlight-icon">
						<svg
							class="w-7 h-7 mx-auto text-white/70"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							viewBox="0 0 24 24"
							><path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path><path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
							></path></svg
						>
					</div>
					<p class="text-slate-400 text-xs uppercase tracking-widest mb-1">
						Modalidad
					</p>
					<p class="text-xl font-semibold text-white">Presencial / UNI</p>
				</div>
				<div class="glow-card text-center">
					<div class="highlight-icon">
						<svg
							class="w-7 h-7 mx-auto text-white/70"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							viewBox="0 0 24 24"
							><path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"
							></path></svg
						>
					</div>
					<p class="text-slate-400 text-xs uppercase tracking-widest mb-1">
						Fechas
					</p>
					<p class="text-xl font-semibold text-white">Próximamente</p>
				</div>
				<div class="glow-card text-center">
					<div class="highlight-icon">
						<svg
							class="w-7 h-7 mx-auto text-[var(--theme-color-primary)]"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							viewBox="0 0 24 24"
							><path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0016.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228M18.75 4.236V2.721"
							></path></svg
						>
					</div>
					<p class="text-slate-400 text-xs uppercase tracking-widest mb-1">
						Premios
					</p>
					<p
						class="text-xl font-semibold bg-gradient-to-r from-[var(--theme-color-primary)] to-[var(--theme-color-secondary)] bg-clip-text text-transparent"
					>
						Próximamente
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- QUÉ ES LA INNOVATHON -->
	<section class="py-24 relative z-10 overflow-hidden">
		<!-- Dynamic Ambient Glows for Mid Section -->
		<div class="absolute -left-[10%] top-1/4 w-[400px] h-[400px] rounded-full bg-[var(--theme-color-glow)] blur-[100px] pointer-events-none opacity-40 z-0"></div>
		<div class="absolute -right-[10%] bottom-1/4 w-[350px] h-[350px] rounded-full bg-[var(--theme-color-glow)] blur-[90px] pointer-events-none opacity-30 z-0"></div>
		<div class="container-custom relative z-10">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
				<!-- Text Content -->
				<div class="reveal">
					<h3 
						class="text-4xl md:text-5xl font-light text-white mb-6"
						style="font-family: var(--font-display);"
					>
						¿Qué es la <br/>
						<span class="font-semibold bg-gradient-to-r from-[var(--theme-color-primary)] to-[var(--theme-color-secondary)] bg-clip-text text-transparent">Innovathon?</span>
					</h3>
					<div class="space-y-6 text-slate-300/80 text-lg font-light leading-relaxed">
						<p>
							La Innovathon es el punto de encuentro donde el talento universitario peruano converge con la tecnología de vanguardia. Durante semanas intensivas de trabajo, equipos multidisciplinarios transforman ideas disruptivas en soluciones funcionales.
						</p>
						<p>
							No es solo una competencia, es una <strong>incubadora acelerada</strong>. Guiados por mentores expertos y potenciados por Inteligencia Artificial, los participantes aprenden a construir productos reales que respondan a los desafíos del mañana.
						</p>
					</div>
					<div class="mt-8 flex flex-wrap gap-4">
						<div class="flex items-center gap-2">
							<div class="w-1.5 h-1.5 rounded-full bg-[var(--theme-color-primary)]"></div>
							<span class="text-sm text-slate-400 uppercase tracking-widest font-semibold">Tecnología</span>
						</div>
						<div class="flex items-center gap-2">
							<div class="w-1.5 h-1.5 rounded-full bg-[var(--theme-color-primary)]"></div>
							<span class="text-sm text-slate-400 uppercase tracking-widest font-semibold">Desarrollo</span>
						</div>
						<div class="flex items-center gap-2">
							<div class="w-1.5 h-1.5 rounded-full bg-[var(--theme-color-secondary)]"></div>
							<span class="text-sm text-slate-400 uppercase tracking-widest font-semibold">Emprendimiento</span>
						</div>
					</div>
				</div>

				<!-- Visual Box -->
				<div class="relative reveal reveal-delayed">
					<!-- Ambient Glow behind the photo (deep, very soft, no harsh borders) -->
					<div class="absolute -inset-10 bg-[var(--theme-color-glow)] rounded-[3rem] blur-[80px] pointer-events-none opacity-45"></div>
					
					<!-- Main Visual Container with Razor-Thin Dynamic Gradient Marco -->
					<div 
						class="relative w-full aspect-[4/3] rounded-[2rem] overflow-hidden p-[1.5px] transition-all duration-500"
						style="background: linear-gradient(135deg, var(--theme-color-primary), var(--theme-color-secondary));"
					>
						<div class="w-full h-full rounded-[1.9rem] bg-slate-950 p-2">
							<div class="w-full h-full rounded-[1.4rem] bg-slate-900 overflow-hidden relative group">
								<img 
									src="/images/photos_innovathon_2025/Innovathon_photo_final_2025_v1.webp" 
									alt="Innovathon 2025" 
									class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.02]" 
								/>
								<div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- AUSPICIADORES -->
	<section class="py-16 relative z-10">
		<div class="container-custom text-center">
			<p
				class="text-xs font-semibold text-slate-500 uppercase tracking-[0.3em] mb-10"
			>
				Auspiciado por
			</p>
			<div class="flex flex-wrap justify-center items-center gap-10 md:gap-16">
				<div class="sponsor-logo">
					<span
						class="text-xl font-black tracking-wider text-white/40 hover:text-white transition-all duration-500"
						>Zoom</span
					>
				</div>
				<div class="sponsor-logo">
					<span
						class="text-xl font-black tracking-wider text-white/40 hover:text-white transition-all duration-500"
						>Linear</span
					>
				</div>
				<div class="sponsor-logo">
					<span
						class="text-xl font-black tracking-wider text-white/40 hover:text-white transition-all duration-500"
						>Wahoo</span
					>
				</div>
				<div class="sponsor-logo">
					<span
						class="text-xl font-black tracking-wider text-white/40 hover:text-white transition-all duration-500"
						>Webflow</span
					>
				</div>
			</div>
		</div>
	</section>

	<!-- INNOVATHON 2025 -->
	<section class="py-24 relative z-10 overflow-hidden">
		<!-- Dynamic Ambient Glows for Lower Section -->
		<div class="absolute right-[5%] top-1/3 w-[500px] h-[500px] rounded-full bg-[var(--theme-color-glow)] blur-[120px] pointer-events-none opacity-30 z-0"></div>
		<div class="absolute left-[5%] bottom-1/3 w-[450px] h-[450px] rounded-full bg-[var(--theme-color-glow)] blur-[110px] pointer-events-none opacity-25 z-0"></div>
		<div
			class="absolute inset-0 bg-gradient-to-b from-transparent via-[var(--theme-color-glow)] to-transparent pointer-events-none z-0"
		>
		</div>
		<div class="container-custom relative z-10">
			<div class="text-center mb-16 reveal">
				<h3
					class="text-4xl md:text-5xl font-light text-white mb-4"
					style="font-family: var(--font-display);"
				>
					Innovathon <span
						class="bg-gradient-to-r from-[var(--theme-color-primary)] to-[var(--theme-color-secondary)] bg-clip-text text-transparent font-semibold"
						>2025</span
					>
				</h3>
				<p class="text-slate-400 text-lg max-w-xl mx-auto font-light">
					Lo que nos dejó la primera edición del evento que unió talento,
					tecnología e innovación.
				</p>
			</div>

			<!-- Stats -->
			<div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-16 reveal-stagger">
				<div class="glow-card glow-card--stat">
					<p
						class="text-4xl md:text-5xl font-extralight bg-gradient-to-b from-white to-white/40 bg-clip-text text-transparent"
					>
						+50
					</p>
					<p class="text-slate-400 text-sm mt-2">Participantes</p>
				</div>
				<div class="glow-card glow-card--stat">
					<p
						class="text-4xl md:text-5xl font-extralight bg-gradient-to-b from-white to-white/40 bg-clip-text text-transparent"
					>
						+12
					</p>
					<p class="text-slate-400 text-sm mt-2">Proyectos</p>
				</div>
				<div class="glow-card glow-card--stat">
					<p
						class="text-4xl md:text-5xl font-extralight bg-gradient-to-b from-white to-white/40 bg-clip-text text-transparent"
					>
						+10
					</p>
					<p class="text-slate-400 text-sm mt-2">Mentores</p>
				</div>
				<div class="glow-card glow-card--stat">
					<p
						class="text-4xl md:text-5xl font-extralight bg-gradient-to-b from-white to-white/40 bg-clip-text text-transparent"
					>
						+4
					</p>
					<p class="text-slate-400 text-sm mt-2">Semanas de trabajo</p>
				</div>
			</div>

			<!-- Proyectos ganadores (Podium Layout) -->
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12 items-center reveal mt-28 mb-16 px-4 md:px-8">
				<!-- Segundo Lugar (Izquierda) -->
				<div class="glow-card order-2 md:order-1 flex flex-col justify-center h-full min-h-[220px]">
					<div class="flex items-center gap-2 mb-2">
						<svg
							class="w-4 h-4 text-[var(--theme-color-primary)]"
							fill="currentColor"
							viewBox="0 0 24 24"
							><path
								d="M5 3h14l-1.5 2h-11L5 3zm7 3a7 7 0 100 14 7 7 0 000-14zm0 2a5 5 0 110 10 5 5 0 010-10z"
							></path></svg
						>
						<span
							class="text-[var(--theme-color-primary)] text-sm font-semibold tracking-wider uppercase"
							>Segundo Lugar</span
						>
					</div>
					<h4 class="text-xl font-semibold text-white mb-2">LlaMasabIA</h4>
					<p class="text-slate-400 text-sm">
						Plataforma eduactiva impulsada con Inteligencia Artificial para
						las zonas rurales del Perú.
					</p>
					<div class="mt-4 flex gap-2">
						<span
							class="px-3 py-1 text-xs rounded-full bg-[var(--theme-color-glow)] text-[var(--theme-color-primary)] border border-[var(--theme-color-primary)]/20"
							>Edtech</span
						>
						<span
							class="px-3 py-1 text-xs rounded-full bg-[var(--theme-color-glow)] text-[var(--theme-color-secondary)] border border-[var(--theme-color-secondary)]/20"
							>IA</span
						>
					</div>
				</div>

				<!-- Primer Lugar (Centro, Más grande) -->
				<div class="glow-card glow-card--featured order-1 md:order-2 md:scale-110 z-10 shadow-2xl relative min-h-[300px]">
					<div
						class="absolute top-0 right-0 w-48 h-48 bg-[var(--theme-color-glow)] rounded-full blur-[80px] pointer-events-none"
					>
					</div>
					<div
						class="absolute bottom-0 left-0 w-32 h-32 bg-[var(--theme-color-glow)] rounded-full blur-[60px] pointer-events-none"
					>
					</div>
					<div class="flex items-center gap-2 mb-4 relative z-10">
						<svg
							class="w-6 h-6 text-[var(--theme-color-primary)]"
							fill="currentColor"
							viewBox="0 0 24 24"
							><path
								d="M5 3h14l-1.5 2h-11L5 3zm7 3a7 7 0 100 14 7 7 0 000-14zm0 2a5 5 0 110 10 5 5 0 010-10zm-1 2v3.5l2.5 1.5.75-1.25L12.5 13V10H11z"
							></path></svg
						>
						<span
							class="text-[var(--theme-color-primary)] text-sm font-semibold tracking-wider uppercase"
							>Proyecto Ganador</span
						>
					</div>
					<h4 class="text-3xl font-semibold text-white mb-3 relative z-10">
						SocIAleye
					</h4>
					<p class="text-slate-300 leading-relaxed relative z-10 text-sm">
						Proyecto que busca fortalecer la convivencia y el bienestar en las
						aulas mediante inteligencia artificial. Su enfoque permite
						identificar dinámicas sociales, detectar señales de riesgo y apoyar
						a docentes en la creación de entornos educativos más seguros e
						inclusivos.
					</p>
					<div class="mt-6 flex flex-wrap gap-2 relative z-10">
						<span
							class="px-3 py-1 text-xs rounded-full bg-[var(--theme-color-glow)] text-[var(--theme-color-primary)] border border-[var(--theme-color-primary)]/20"
							>Educación</span
						>
						<span
							class="px-3 py-1 text-xs rounded-full bg-[var(--theme-color-glow)] text-[var(--theme-color-primary)] border border-[var(--theme-color-primary)]/20"
							>IA</span
						>
						<span
							class="px-3 py-1 text-xs rounded-full bg-[var(--theme-color-glow)] text-[var(--theme-color-secondary)] border border-[var(--theme-color-secondary)]/20"
							>Computer Vision</span
						>
					</div>
				</div>

				<!-- Tercer Lugar (Derecha) -->
				<div class="glow-card order-3 flex flex-col justify-center h-full min-h-[220px]">
					<div class="flex items-center gap-2 mb-2">
						<svg
							class="w-4 h-4 text-[var(--theme-color-secondary)]"
							fill="currentColor"
							viewBox="0 0 24 24"
							><path
								d="M5 3h14l-1.5 2h-11L5 3zm7 3a7 7 0 100 14 7 7 0 000-14zm0 2a5 5 0 110 10 5 5 0 010-10z"
							></path></svg
						>
						<span
							class="text-[var(--theme-color-secondary)] text-sm font-semibold tracking-wider uppercase"
							>Tercer Lugar</span
						>
					</div>
					<h4 class="text-xl font-semibold text-white mb-2">
						RiqchariyFinanzas
					</h4>
					<p class="text-slate-400 text-sm">
						Finanzas educativas para escolares y personas iniciando en el
						ecosistema financiero.
					</p>
					<div class="mt-4 flex gap-2">
						<span
							class="px-3 py-1 text-xs rounded-full bg-[var(--theme-color-glow)] text-[var(--theme-color-secondary)] border border-[var(--theme-color-secondary)]/20"
							>Fintech</span
						>
					</div>
				</div>
			</div>
