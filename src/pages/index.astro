---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Inicio">
	<section class="py-24 relative overflow-hidden">
		<!-- Background Glow -->
		<div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[500px] bg-blue-600/10 blur-[120px] rounded-full -z-10"></div>
		
		<div class="container-custom text-center">
			<span class="inline-block px-4 py-1.5 mb-6 text-xs font-bold tracking-widest uppercase bg-blue-500/10 text-blue-400 rounded-full border border-blue-500/20">
				Launch with AI 2026
			</span>
			<h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-8 leading-tight">
				¡Haz que tu talento <br />
				<span class="bg-gradient-to-r from-blue-400 via-indigo-500 to-purple-600 bg-clip-text text-transparent">deje huella!</span>
			</h1>
			<p class="text-xl text-slate-400 max-w-2xl mx-auto mb-12">
				Descubre el evento universitario de innovación donde tus ideas se transforman en impacto real asistido por Inteligencia Artificial.
			</p>
			
			<div class="flex flex-wrap justify-center gap-4">
				<a href="#" class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-4 rounded-xl font-bold transition-all shadow-lg shadow-blue-900/20">
					Bases del Concurso
				</a>
				<a href="#" class="bg-white/5 hover:bg-white/10 text-white px-8 py-4 rounded-xl font-bold border border-white/10 transition-all">
					Ver Cronograma
				</a>
			</div>
		</div>
	</section>
</Layout>
