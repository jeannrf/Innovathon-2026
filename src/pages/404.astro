---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - No Encontrado">
	<div class="container-custom h-[60vh] flex flex-col items-center justify-center text-center">
		<h1 class="text-9xl font-black text-white/10 absolute -z-10">404</h1>
		<h2 class="text-4xl font-bold mb-4">Página no encontrada</h2>
		<p class="text-slate-400 mb-8 max-w-md">Lo sentimos, la página que estás buscando no existe o ha sido movida.</p>
		<a href="/" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-bold transition-all">
			Volver al inicio
		</a>
	</div>
</Layout>
