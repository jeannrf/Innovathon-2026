---
// src/components/layout/Footer.astro
const year = new Date().getFullYear();
---
<footer class="bg-slate-950 border-t border-white/5 py-12">
  <div class="container-custom">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <div class="col-span-1 md:col-span-2">
        <h3 class="text-lg font-bold mb-4">Innovathon "Launch with AI"</h3>
        <p class="text-slate-400 max-w-xs text-sm">
          Impulsando el emprendimiento universitario con inteligencia artificial.
          Organizado por la alianza TinkuyLabs (CCAT, CODE, CEIIS y DSC).
        </p>
      </div>
      
      <div>
        <h4 class="font-semibold mb-4">Secciones</h4>
        <ul class="space-y-2 text-sm text-slate-400">
          <li><a href="#" class="hover:text-blue-400">Términos y condiciones</a></li>
          <li><a href="#" class="hover:text-blue-400">Políticas de privacidad</a></li>
          <li><a href="#" class="hover:text-blue-400">Preguntas Frecuentes</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold mb-4">Contacto</h4>
        <p class="text-sm text-slate-400">tinkuylabs@uni.edu.pe</p>
        <p class="text-sm text-slate-400">+51 980 270 642</p>
      </div>
    </div>
    
    <div class="mt-12 pt-8 border-t border-white/5 text-center text-xs text-slate-500">
      &copy; {year} Innovathon – TinkuyLabs. Todos los derechos reservados.
    </div>
  </div>
</footer>
